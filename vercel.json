{
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "client"
    }
  ],
  "functions": {
    "server/index.js": {
      "includeFiles": "server/**/*"
    }
  }
}